{
  "title": "Break Tester",
  "uid": "break-tester",
  "version": 2,
  "schemaVersion": 39,
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": { "refresh_intervals": ["5s", "10s", "30s", "1m"] },
  "refresh": "5s",
  "panels": [
    {
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(break_tester_requests_total)",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green" } ] },
          "unit": "short"
        }
      }
    },
    {
      "title": "Success Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 0 },
      "targets": [
        {
          "expr": "sum(break_tester_requests_total{status=~\"2\\\\d\\\\d\"}) / sum(break_tester_requests_total) * 100",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 95, "color": "orange" },
              { "value": 99, "color": "green" }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "title": "Current RPS",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(break_tester_requests_total[5s]))",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue" } ] },
          "unit": "reqps"
        }
      }
    },
    {
      "title": "Avg Latency",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(break_tester_request_duration_seconds_bucket[5s])) by (le))",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.5, "color": "orange" },
              { "value": 1.0, "color": "red" }
            ]
          },
          "unit": "s",
          "decimals": 3
        }
      }
    },
    {
      "title": "Error Rate (4xx/5xx)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(break_tester_requests_total{status=~\"4\\\\d\\\\d|5\\\\d\\\\d|error\"}[5s])) / sum(rate(break_tester_requests_total[5s])) * 100",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "orange" },
              { "value": 5, "color": "red" }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "title": "Peak Latency (p99)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(break_tester_request_duration_seconds_bucket[5s])) by (le))",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1.0, "color": "orange" },
              { "value": 3.0, "color": "red" }
            ]
          },
          "unit": "s",
          "decimals": 3
        }
      }
    },
    {
      "title": "Throughput (RPS)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(break_tester_requests_total{status=~\"2\\\\d\\\\d\"}[5s]))",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green" } ] },
          "unit": "reqps"
        }
      }
    },
    {
      "title": "Active Users (Concurrency)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(break_tester_requests_total[5s])) / (histogram_quantile(0.50, sum(rate(break_tester_request_duration_seconds_bucket[5s])) by (le)) + 0.001)",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "purple" } ] },
          "unit": "short"
        }
      }
    },
    {
      "title": "Request Rate by Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(break_tester_requests_total[5s])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Request Rate by Method",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(break_tester_requests_total[5s])) by (method)",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Latency Percentiles (p50 / p90 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(break_tester_request_duration_seconds_bucket[5s])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(break_tester_request_duration_seconds_bucket[5s])) by (le))",
          "legendFormat": "p90",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(break_tester_request_duration_seconds_bucket[5s])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Latency Distribution (Heatmap)",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(break_tester_request_duration_seconds_bucket[5s])) by (le)",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "heatmap": {
        "yAxis": {
          "format": "s",
          "logBase": 2
        }
      }
    },
    {
      "title": "Total Requests by Status",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum(break_tester_requests_total) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-gr" },
          "custom": { "orientation": "horizontal" }
        }
      }
    },
    {
      "title": "Requests by Method",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 20 },
      "targets": [
        {
          "expr": "sum(break_tester_requests_total) by (method)",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Status Breakdown by Method",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "sum(break_tester_requests_total) by (status, method)",
          "legendFormat": "__auto",
          "refId": "A",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "job": true, "instance": true },
            "indexByName": {},
            "renameByName": {}
          }
        }
      ]
    }
  ]
}
